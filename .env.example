# Copy this file to `.env` in this directory (Compose loads it for `paper` + `discord-bot`).
# `.env` is gitignored тАФ never commit real keys.
# For Discord bot variables, copy the rest from `bot-service/env.example` into the same `.env`.

# Stripe (JebaitedCore /donate) тАФ test or live secret key
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (whsec_...) тАФ Dashboard endpoint or `stripe listen` output
STRIPE_WEBHOOK_SECRET=

# Paper Minecraft on host (inside container still 25565). Default 25566 if jebaited-mc/other uses 25565.
# PAPER_HOST_PORT=25565
