# Copy to repo-root ".env" (next to docker-compose.yml) for Docker Compose.
# See comments for where each value comes from.

# Aliases also accepted: DISCORD_BOT_TOKEN, DISCORD_TOKEN, BOT_TOKEN (env and .env)
# Auto-discovered without copying: .../JebaitedNetwork/.env when working dir is under IdeaProjects (see ConfigLoader).
JB_BOT_TOKEN=
# After toggling Privileged Gateway Intents in Discord Developer Portal (Server Members, Message Content), set:
# JB_DISCORD_PRIVILEGED_INTENTS=true
JB_DISCORD_PRIVILEGED_INTENTS=false
JB_BOT_GUILD_ID=
JB_BOT_STATUS_TEXT=Watching Jebaited

JB_DB_JDBC_URL=jdbc:postgresql://host.docker.internal:5432/jebaited
JB_DB_USERNAME=user
JB_DB_PASSWORD=

JB_REDIS_URI=redis://host.docker.internal:6379
JB_REDIS_CHANNEL=jebaited.events

JB_HTTP_HOST=0.0.0.0
JB_HTTP_PORT=8787

JB_WEBHOOK_SECRET=
JB_MAX_SKEW_SECONDS=120

JB_ROLE_PLEB=
JB_ROLE_VIP=
JB_ROLE_BUILDER=
JB_ROLE_GOLD=
JB_ROLE_DIAMOND=
JB_ROLE_LEGEND=
JB_ROLE_GRANDMASTER=
JB_ROLE_HELPER=
JB_ROLE_MODERATOR=
JB_ROLE_SRMOD=
JB_ROLE_ADMIN=
JB_ROLE_DEVELOPER=
JB_ROLE_OWNER=

# Discord channel / role IDs (right-click channel/role → Copy ID)
JB_MOD_LOGS_CHANNEL_ID=
JB_ANNOUNCEMENTS_CHANNEL_ID=
JB_EVENTS_PING_ROLE_ID=
JB_RELAY_OUT_CHANNEL_ID=
JB_RELAY_STAFF_OUT_CHANNEL_ID=
JB_RELAY_FACTION_OUT_CHANNEL_ID=
JB_RELAY_GLOBAL_IN_CHANNEL_ID=
JB_RELAY_STAFF_IN_CHANNEL_ID=
JB_RELAY_FACTION_IN_CHANNEL_ID=
JB_CONSOLE_CHANNEL_ID=
JB_CONSOLE_DEVELOPER_ROLE_ID=
# Paper plugin HTTP (Bearer JB_PLUGIN_API_TOKEN); host must reach the MC server bind (e.g. host.docker.internal:8789)
JB_PLUGIN_INBOUND_BASE_URL=http://host.docker.internal:8789
JB_PLUGIN_API_TOKEN=
JB_STATUS_EMBED_CHANNEL_ID=
